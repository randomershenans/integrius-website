// ─────────────────────────────────────────────────────────────────────────────
// INTEGRIUS CMS — Prisma Schema
//
// THIS IS THE MARKETING SITE ADMIN. NOT THE INTEGRIUS PRODUCT.
// All tables are prefixed with cms_ to avoid any collision with product tables.
// Portal tables live in Supabase — see supabase/migrations/ for their schema.
//
// The blog itself is git-native (markdown in content/blog/, see
// content/blog/README.md); the old cms_articles / cms_article_specs /
// cms_generation_queue / cms_keyword_clusters tables were dropped in
// 20260612000001_drop_cms_content_tables.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Admin users for the admin UI — completely separate from product users
model cms_admin_users {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  password_hash String
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  last_login_at DateTime? @db.Timestamptz(6)

  @@index([email])
}
