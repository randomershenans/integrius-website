# ─────────────────────────────────────────────────────────────────────────────
# INTEGRIUS CMS — Environment Variables
#
# THIS IS THE MARKETING BLOG CMS. NOT THE INTEGRIUS PRODUCT.
# Copy to .env.local and fill in values.
# ─────────────────────────────────────────────────────────────────────────────

# Database — can share the same Postgres as the product (uses cms_ prefixed tables)
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# Admin auth — the CMS admin login password (hashed at first run)
CMS_ADMIN_EMAIL="ross@integrius.io"
CMS_ADMIN_PASSWORD="change-this-to-something-strong"
CMS_JWT_SECRET="generate-a-random-32-char-string-here"

# Claude AI (Anthropic) — for article generation
ANTHROPIC_API_KEY="sk-ant-..."

# LinkedIn — for auto-sharing published articles to the company page
# Get from: https://developer.linkedin.com/
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_ACCESS_TOKEN=""       # OAuth 2.0 access token for the company page
LINKEDIN_ORGANIZATION_ID=""    # LinkedIn company page URN (e.g. urn:li:organization:12345678)

# Resend — for contact form email delivery
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_..."

# Site config
NEXT_PUBLIC_SITE_URL="https://integri.us"
NEXT_PUBLIC_SITE_NAME="Integrius"

# ─────────────────────────────────────────────────────────────────────────────
# CLIENT PORTAL — Supabase Auth
# Get from: https://supabase.com/dashboard/project/<your-project>/settings/api
# ─────────────────────────────────────────────────────────────────────────────

# Public Supabase URL (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxxxxxxxxxx.supabase.co"

# Public anon key (safe to expose to browser — RLS enforces security)
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Service role key — server-side ONLY. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
