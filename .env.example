# ─────────────────────────────────────────────────────────────────────────────
# INTEGRIUS CMS — Environment Variables
#
# THIS IS THE MARKETING BLOG CMS. NOT THE INTEGRIUS PRODUCT.
# Copy to .env.local and fill in values.
# ─────────────────────────────────────────────────────────────────────────────

# Database — can share the same Postgres as the product (uses cms_ prefixed tables)
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# Admin auth — the CMS admin login password (hashed at first run)
CMS_ADMIN_EMAIL="ross@integrius.io"
CMS_ADMIN_PASSWORD="change-this-to-something-strong"
CMS_JWT_SECRET="generate-a-random-32-char-string-here"

# Claude AI (Anthropic) — for article generation
ANTHROPIC_API_KEY="sk-ant-..."

# LinkedIn — for auto-sharing published articles to the company page
# Get from: https://developer.linkedin.com/
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_ACCESS_TOKEN=""       # OAuth 2.0 access token for the company page
LINKEDIN_ORGANIZATION_ID=""    # LinkedIn company page URN (e.g. urn:li:organization:12345678)

# Cron — secret for securing scheduled cron endpoints (e.g. /api/cron/publish)
CRON_SECRET="generate-a-random-32-char-string-here"

# Resend — for contact form email delivery
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_..."

# Site config
NEXT_PUBLIC_SITE_URL="https://integri.us"
NEXT_PUBLIC_SITE_NAME="Integrius"

# ─────────────────────────────────────────────────────────────────────────────
# CLIENT PORTAL — Supabase Auth
# Get from: https://supabase.com/dashboard/project/<your-project>/settings/api
# ─────────────────────────────────────────────────────────────────────────────

# Public Supabase URL (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxxxxxxxxxx.supabase.co"

# Public publishable key (safe to expose to browser — RLS enforces security)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="eyJ..."

# Secret key — server-side ONLY. Never expose to client.
# Used by supabase-admin.ts for privileged operations.
SUPABASE_SECRET_KEY="eyJ..."

# ─────────────────────────────────────────────────────────────────────────────
# Contact form
# ─────────────────────────────────────────────────────────────────────────────

# Recipient email for the contact form (defaults to info@integri.us if unset)
CONTACT_FORM_RECIPIENT="info@integri.us"

# ─────────────────────────────────────────────────────────────────────────────
# AGENTIC SEO ENGINE — see docs/AGENTIC-SEO.md for setup
# ─────────────────────────────────────────────────────────────────────────────

# Google Search Console — service account email (Search Console API enabled, added as a user on the GSC property)
GSC_CLIENT_EMAIL="seo-brain@your-project.iam.gserviceaccount.com"
# Google Search Console — service account private key, PEM with \n escapes
GSC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Google Search Console — the property to query, e.g. sc-domain:integri.us or https://integri.us/
GSC_SITE_URL="sc-domain:integri.us"

# PostHog — personal API key with query:read scope (server-side only)
POSTHOG_PERSONAL_API_KEY="phx_..."
# PostHog — numeric project id (from project settings)
POSTHOG_PROJECT_ID="12345"
# PostHog — API host, defaults to the EU cloud if unset
POSTHOG_API_HOST="https://eu.posthog.com"

# PostHog browser snippet — public project API key (safe to expose)
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
# PostHog browser snippet — ingestion host for the browser client
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# SEO brain — maximum complete articles written (and PR'd) per run, default 2
SEO_BRAIN_MAX_ARTICLES="2"

# GitHub — repo-scoped personal access token used to open content PRs
GITHUB_TOKEN="ghp_..."
# GitHub — the site repo as owner/repo
GITHUB_REPO="randomershenans/integrius-website"
# GitHub — base branch PRs target, defaults to master
GITHUB_BASE_BRANCH="master"
