{
  "name": "integrius-cms",
  "version": "1.0.0",
  "private": true,
  "description": "Integrius marketing blog CMS — SEPARATE from the Integrius product. Do not import or reference from the main app.",
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx --env-file .env prisma/seed.ts",
    "db:seed-v2": "tsx --env-file .env prisma/seed-v2-comparison-specs.ts",
    "db:studio": "prisma studio --port 5556"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.100.0",
    "@tailwindcss/typography": "^0.5.19",
    "bcryptjs": "^2.4.3",
    "framer-motion": "^12.38.0",
    "jose": "^5.9.6",
    "lucide-react": "^0.577.0",
    "next": "^14.2.29",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "resend": "^6.9.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
